# ═══════════════════════════════════════════
# AudioMind 环境变量
# 复制为 .env 后填入真实值
# ═══════════════════════════════════════════

# ── ASR 语音转写 ──────────────────────────
# local = 本地 faster-whisper (端口 8081，无需 API Key)
# api   = 云端 Whisper API (需 OPENAI_API_KEY)
ASR_MODE=local
LOCAL_ASR_URL=http://localhost:8081

# 仅 ASR_MODE=api 时需要:
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# WHISPER_MODEL=whisper-1

# ── Dify 智能体（必填） ───────────────────
DIFY_API_URL=https://cloud.dify.ai/v1
DIFY_API_KEY=app-xxxxxxxxxxxxx
DIFY_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── 服务端口 ──────────────────────────────
PORT=8080
